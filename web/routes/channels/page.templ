package appsrc

import (
	"blog/web/view"
	"blog/web/components"
	i18nkeys "blog/web/generated/i18nkeys"
)

templ Page(view runtime.NotesPageView) {
	<section class="channels-page">
		<header class="channels-page-header channels-desktop-hint">
			<h1>{ i18nkeys.TChannelsPageTitle(view.I18n()) }</h1>
			<p class="muted">{ i18nkeys.TChannelsPageHint(view.I18n()) }</p>
			<a class="back-link channels-back-button" href={ runtime.BuildNotesFilterURL(view.LocaleCode(), 1, view.Filter.AuthorSlug, view.Filter.TagName, view.Filter.Type, view.Filter.Query) }>{ i18nkeys.TChannelsPageBack(view.I18n()) }</a>
		</header>

		<section class="channel-panel-standalone channels-mobile-panel">
			<div class="channel-scroll">
				@components.ChannelList(view)
			</div>
		</section>
	</section>
}
