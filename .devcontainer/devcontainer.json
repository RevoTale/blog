{
  "name": "RevoTale Blog",
  "dockerComposeFile": "docker-compose.yml",
  "service": "devcontainer",
  "runServices": [
    "cms_postgres",
    "rustfs",
    "setup-rustfs",
    "cms",
    "imgproxy",
    "proxy"
  ],
  "workspaceFolder": "/workspaces/blog",
  "mounts": [
    "source=${localEnv:HOME}/.codex,target=/home/vscode/.codex,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.cursor,target=/home/vscode/.cursor,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.continue,target=/home/vscode/.continue,type=bind,consistency=cached"
  ],
  "shutdownAction": "stopCompose",
  "features": {
    "ghcr.io/devcontainers-extra/features/go-task:1": {}
  },
  "postCreateCommand": "go install github.com/a-h/templ/cmd/templ@v0.3.1001",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "a-h.templ"
      ]
    }
  }
}
